extends ../_.pug

block content
  h1 Button Set
  p Button set.
  h2 Examples
  h3 Basic
  pre: code
    | &lt;p class="flex-fill has-gap to-center" role="group"&gt;
    |   &lt;span class="button-set" role="group"&gt;
    |     &lt;button class="button"&gt;
    |       Button 1
    |     &lt;/button&gt;
    |     &lt;button class="button"&gt;
    |       Button 2
    |     &lt;/button&gt;
    |     &lt;button class="button"&gt;
    |       Button 3
    |     &lt;/button&gt;
    |   &lt;/span&gt;
    |   &lt;button class="button"&gt;
    |     Button 4
    |   &lt;/button&gt;
    | &lt;/p&gt;
  #test-1.has-fill.has-pad.has-stroke
    p.flex-fill.has-gap.to-center(role='group')
      span.button-set(role='group')
        button.button Button 1
        button.button Button 2
        button.button Button 3
      button.button Button 4
  h3 With Arrow
  pre: code
    | &lt;p class="flex-fill has-gap to-center" role="group"&gt;
    |   &lt;span class="button-set" role="group"&gt;
    |     &lt;button class="button has-title"&gt;
    |       &lt;span class="button-title title"&gt;
    |         Button 1
    |       &lt;/span&gt;
    |     &lt;/button&gt;
    |     &lt;button class="button has-arrow" title="More&amp;hellip;"&gt;
    |       &lt;span class="arrow button-arrow to-bottom"&gt;&lt;/span&gt;
    |     &lt;/button&gt;
    |   &lt;/span&gt;
    |   &lt;button class="button"&gt;
    |     Button 2
    |   &lt;/button&gt;
    | &lt;/p&gt;
  #test-2.has-fill.has-pad.has-stroke
    p.flex-fill.has-gap.to-center(role='group')
      span.button-set(role='group')
        button.button.has-title
          span.button-title.title Button 1
        button.button.has-arrow(title!='More&hellip;')
          span.arrow.button-arrow.to-bottom
      button.button Button 2
  h3 With Icon
  pre: code
    | &lt;p class="flex-fill has-gap to-center" role="group"&gt;
    |   &lt;span class="button-set" role="group"&gt;
    |     &lt;button class="button has-icon" title="Select&amp;hellip;"&gt;
    |       &lt;svg class="button-icon icon" height="24" viewBox="0 0 24 24" width="24"&gt; &hellip; &lt;/svg&gt;
    |     &lt;/button&gt;
    |     &lt;button class="button has-title"&gt;
    |       &lt;span class="button-title title"&gt;
    |         Button 1
    |       &lt;/span&gt;
    |     &lt;/button&gt;
    |   &lt;/span&gt;
    |   &lt;button class="button"&gt;
    |     Button 2
    |   &lt;/button&gt;
    | &lt;/p&gt;
  #test-3.has-fill.has-pad.has-stroke
    p.flex-fill.has-gap.to-center(role='group')
      span.button-set(role='group')
        button.button.has-icon(title!='Select&hellip;')
          svg.button-icon.icon(height='24' viewBox='0 0 24 24' width='24')
            path(d='M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6z')
        button.button.has-title
          span.button-title.title Button 1
      button.button Button 2
  h3 With Radios
  pre: code
    | &lt;form&gt;
    |   &lt;p class="flex-fill has-gap to-center" role="group"&gt;
    |     &lt;span class="button-set" role="group"&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-2" type="radio" value="1"&gt; Button 1
    |       &lt;/label&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-2" type="radio" value="2"&gt; Button 2
    |       &lt;/label&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-2" type="radio" value="3"&gt; Button 3
    |       &lt;/label&gt;
    |     &lt;/span&gt;
    |     &lt;button class="button"&gt;
    |       Button 4
    |     &lt;/button&gt;
    |   &lt;/p&gt;
    | &lt;/form&gt;
  form#test-4.has-fill.has-pad.has-stroke
    p.flex-fill.has-gap.to-center(role='group')
      span.button-set(role='group')
        label.button
          input(name='test-4' type='radio' value='1')
          = ' Button 1'
        label.button
          input(name='test-4' type='radio' value='2')
          = ' Button 2'
        label.button
          input(name='test-4' type='radio' value='3')
          = ' Button 3'
      button.button(type='button') Button 4
  h3 With Checks
  pre: code
    | &lt;form&gt;
    |   &lt;p class="flex-fill has-gap to-center" role="group"&gt;
    |     &lt;span class="button-set" role="group"&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-3" type="checkbox" value="1"&gt; Button 1
    |       &lt;/label&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-3" type="checkbox" value="2"&gt; Button 2
    |       &lt;/label&gt;
    |       &lt;label class="button"&gt;
    |         &lt;input name="test-3" type="checkbox" value="3"&gt; Button 3
    |       &lt;/label&gt;
    |     &lt;/span&gt;
    |     &lt;button class="button"&gt;
    |       Button 4
    |     &lt;/button&gt;
    |   &lt;/p&gt;
    | &lt;/form&gt;
  form#test-5.has-fill.has-pad.has-stroke
    p.flex-fill.has-gap.to-center(role='group')
      span.button-set(role='group')
        label.button
          input(name='test-5' type='checkbox' value='1')
          = ' Button 1'
        label.button
          input(name='test-5' type='checkbox' value='2')
          = ' Button 2'
        label.button
          input(name='test-5' type='checkbox' value='3')
          = ' Button 3'
      button.button(type='button') Button 4

